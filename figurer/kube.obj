# Simple cube, counter-clockwise winding
v -100  100  100
v  100  100  100
v  100 -100  100
v -100 -100  100
v -100  100 -100
v  100  100 -100
v  100 -100 -100
v -100 -100 -100

# Front (z=400, facing +z)
f 1 3 2
f 1 4 3
# Back (z=-400, facing -z)
f 5 6 7
f 5 7 8
# Left (x=-100, facing -x)
f 5 4 1
f 5 8 4
# Right (x=400, facing +x)
f 2 7 6
f 2 3 7
# Top (y=100, facing -y)
f 5 6 2
f 5 2 1
# Bottom (y=-400, facing -y)
f 4 7 3
f 4 8 7

c 245 194 17 
c 51 209 122
c 237 51 59
c 28 113 216
c 192 97 203
c 255 120 0
